# ── Copy this file to .env and customise values ────────────────────────────

# ISO 3166-1 alpha-2 country code for the default trend region
TARGET_REGION=US

# Active trend provider: google | youtube
TREND_PROVIDER=google

# Storage paths (relative to project root)
RAW_DATA_PATH=data/raw
PROCESSED_DATA_PATH=data/processed
BRIEFS_DATA_PATH=data/briefs

# pytrends configuration
PYTRENDS_HL=en-US
PYTRENDS_TZ=360
PYTRENDS_RETRIES=3
PYTRENDS_BACKOFF_FACTOR=5.0

# Logging verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO